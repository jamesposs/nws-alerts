# Copy this file to .env and adjust for your printer and location.

# NWS point to monitor. Enter your lat/long here.
NWS_LATITUDE=40.016869
NWS_LONGITUDE=105.270546

# NWS asks clients to send a unique User-Agent. Include contact info you control.
NWS_USER_AGENT=(nws-alerts, your-email@example.com)
NWS_ACCEPT=application/geo+json

# Keep live polling at 30 seconds or slower to respect NWS alerts guidance.
POLL_INTERVAL_SECONDS=30
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_SECONDS=2
HTTP_MAX_BACKOFF_SECONDS=120

# Local timezone for receipt timestamps.
TIMEZONE=America/Denver
IMMEDIATE_THRESHOLD_SECONDS=120

# Network ESC/POS printer settings.
PRINTER_IP=192.168.1.10
PRINTER_PORT=9100
PRINTER_TIMEOUT_SECONDS=10
PRINT_WIDTH_PIXELS=576
CUT_PAPER=true

# When true, do everything except open the printer socket.
PRINTER_DRY_RUN=false

# Filtering is case-insensitive. Leave an allowlist blank to avoid restricting on that field.
# Common strategy: only warnings
ALLOWED_EVENTS=Severe Thunderstorm Warning,Tornado Warning,Flash Flood Warning

# Common strategy: warnings + watches
# ALLOWED_EVENTS=Severe Thunderstorm Warning,Severe Thunderstorm Watch,Tornado Warning,Tornado Watch,Flash Flood Warning,Flash Flood Watch

# Common strategy: print everything for the configured point
# ALLOWED_EVENTS=
# ALLOWED_SEVERITIES=
# ALLOWED_URGENCIES=
# ALLOWED_CERTAINTIES=
# ALLOWED_STATUSES=
# ALLOWED_MESSAGE_TYPES=

# Blocklist overrides allowlists. Use this to exclude statements while still printing warnings.
# Example to exclude Special Weather Statements:
# BLOCKED_EVENTS=Special Weather Statement
BLOCKED_EVENTS=

ALLOWED_SEVERITIES=Severe,Extreme
ALLOWED_URGENCIES=Immediate,Expected
ALLOWED_CERTAINTIES=Observed,Likely
ALLOWED_STATUSES=Actual
ALLOWED_MESSAGE_TYPES=Alert

# Behavior
PRINT_ON_NEW_ONLY=true
PRINT_ON_UPDATES=false
STATE_FILE=./data/printed_alerts.json
LOG_LEVEL=INFO

# Spoof mode: point this at a local GeoJSON file for full testing without waiting on live weather.
# In spoof mode, you can lower POLL_INTERVAL_SECONDS below 30.
SPOOF_ALERTS_FILE=
